// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id
  nickname   String?
  email      String
  provider   String // eg: 'google', 'kakao', 'facebook', 'local'
  providerId String?  @unique @map("provider_id") // 해당 플랫폼의 user ID
  idToken    String?  @map("id_token") // OIDC용 (Google, Apple 등)
  password   String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  imageUrl   String?  @map("image_url")

  products     Product[]
  articles     Article[]
  images       Image[]
  productLikes ProductLike[]
  articleLikes ArticleLike[]

  @@unique(name: "emailProvider", [email, provider])
  @@map("users")
}

model Product {
  id          String   @id
  name        String
  description String
  price       Float
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  userId      String   @map("user_id")
  likeCnt     BigInt   @map("like_cnt") @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  rootComments RootCommentToProduct[]
  tags         ProductTag[]
  productLikes ProductLike[]

  @@map("products")
}

model ProductLike {
  id String @id

  productId String @map("product_id")
  userId    String @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique(name: "productUser", [productId, userId])
  @@map("product_likes")
}

model Tag {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productTags ProductTag[]

  @@map("tags")
}

model ProductTag {
  id        String @id
  productId String @map("product_id")
  tagId     String @map("tag_id")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("product_tags")
}

model RootCommentToProduct {
  productId String @map("product_id")
  commentId String @map("comment_id")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([productId, commentId])
  @@map("root_comments_to_product")
}

model Article {
  id        String   @id
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    String   @map("user_id")
  likeCnt   BigInt   @map("like_cnt") @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  rootComments RootCommentToArticle[]
  articleLikes ArticleLike[]

  @@map("articles")
}

model ArticleLike {
  id String @id

  articleId String @map("article_id")
  userId    String @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique(name: "articleUser", [articleId, userId])
  @@map("article_likes")
}

model Comment {
  id        String   @id
  parentId  String?  @map("parent_id")
  replyId   String?  @map("reply_id")
  title     String?
  content   String
  userId    String   @map("user_id")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Comment?  @relation("CommentToComments", fields: [parentId], references: [id], onDelete: Cascade)
  comments Comment[] @relation("CommentToComments")

  rootCommentsOfArticle RootCommentToArticle[]
  rootCommentsOfProduct RootCommentToProduct[]

  @@map("comments")
}

model RootCommentToArticle {
  articleId String @map("article_id")
  commentId String @map("comment_id")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([articleId, commentId])
  @@map("root_comments_to_article")
}

